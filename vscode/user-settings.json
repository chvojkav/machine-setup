{
    "cSpell.userWords": [
        "debugované",
        "golangci",
        "kubernet",
        "resolv",
        "seniorní",
        "trimpath"
    ],
    "too-long-line-limit.softLimitSeverity": "3",
    "too-long-line-limit.softLimit": 120,
    "editor.rulers": [
        120,
        120
    ],
    "too-long-line-limit.hardLimitSeverity": "1",
    "cSpell.language": "en,cs",
    "redhat.telemetry.enabled": false,
    "remote.defaultExtensionsIfInstalledLocally": [
        "GitHub.vscode-pull-request-github"
    ],
    "editor.codeActionsOnSave": {},
    "go.toolsManagement.autoUpdate": true,
    "inlineChat.affordance": "off",
    "inlineChat.fixDiagnostics": false,
    "chat.sendElementsToChat.enabled": false,
    "chat.sendElementsToChat.attachCSS": false,
    "chat.useHooks": false,
    "editor.lightbulb.enabled": "off",
    "terminal.integrated.shellIntegration.quickFixEnabled": false,
    "workbench.colorTheme": "Dark Modern",
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.defaultColorDecorators": "never",
        "editor.formatOnType": true,
        "editor.wordBasedSuggestions": "off"
    },
    "explorer.confirmDelete": false,
    "python.analysis.typeCheckingMode": "standard",
    "python.defaultInterpreterPath": "/home/chvojka/.venvs/vsh-pytest/bin/python",
    "python.experiments.enabled": false,
    "python.venvFolders": [
        "/.venvs/vsh-pytest"
    ],
    "python.useEnvironmentsExtension": true,
}
